modules = ["nodejs-20", "web", "python-3.11", "postgresql-16"]
run = "npm run dev"

[nix]
channel = "stable-25_05"

[deployment]
run = ["node", "api/server.js"]
deploymentTarget = "autoscale"
build = ["npm", "run", "build"]
publicDir = "dist/public"

[[ports]]
localPort = 3001
externalPort = 3001

[[ports]]
localPort = 4321
externalPort = 4200

[[ports]]
localPort = 4322
externalPort = 5173

[[ports]]
localPort = 4323
externalPort = 6000

[[ports]]
localPort = 4324
externalPort = 6800

[[ports]]
localPort = 4325
externalPort = 8008

[[ports]]
localPort = 4326
externalPort = 8080

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5123
externalPort = 5000

[[ports]]
localPort = 8765
externalPort = 3003

[[ports]]
localPort = 8888
externalPort = 3002

[[ports]]
localPort = 9998
externalPort = 8000

[[ports]]
localPort = 9999
externalPort = 3000

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "App"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend"

[[workflows.workflow]]
name = "App"
author = "agent"

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "npm run dev"
waitForPort = 5000

[[workflows.workflow]]
name = "Backend"
author = "agent"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "node api/server.js"
waitForPort = 3001

[auth]
pageEnabled = false
buttonEnabled = false

[agent]
expertMode = true
integrations = ["javascript_database:1.0.0"]

[userenv]

[userenv.shared]

[userenv.development]
PORT = "3001"
NODE_ENV = "development"

[userenv.production]
PORT = "5000"
NODE_ENV = "production"
